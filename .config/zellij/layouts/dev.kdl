layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="zellij:tab-bar"
    }
    children
  }

  tab name="EDIT" {
    pane command="nvim" {
    }
  }

  tab name="RUN" {
    pane
  }

  tab name="LOGS" {
    pane
  }

  tab name="GIT" {
    pane command="lazygit"
  }

  tab name="SHELL" {
    pane
  }

  tab name="MONITOR" {
    pane command="btop"
  }
}
